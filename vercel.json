{
  "version": 2,
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/next",
      "config": { "distDir": ".next" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "web/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "@fyr_api_url",
    "NEXT_PUBLIC_SUPABASE_URL": "@fyr_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@fyr_supabase_anon_key"
  }
}
